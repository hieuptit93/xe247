# ═══════════════════════════════════════════════════════════════
# XE 247 - Data Collection API Keys
# ═══════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────
# FREE APIs (Recommended)
# ──────────────────────────────────────────────────────────────

# OpenStreetMap - NO KEY NEEDED (100% free, unlimited)

# OpenChargeMap - FREE (get key at https://openchargemap.org/site/develop/api)
OPENCHARGE_API_KEY=your_opencharge_key_here

# Foursquare - FREE TIER 99,999 calls/month
# Get key at: https://foursquare.com/developers/signup
FOURSQUARE_API_KEY=your_foursquare_key_here

# ──────────────────────────────────────────────────────────────
# PAID APIs (Optional - only if you need more data)
# ──────────────────────────────────────────────────────────────

# Google Places API - ~$100-150 for full collection
# Only use if free sources don't have enough data
GOOGLE_PLACES_API_KEY=your_google_api_key_here

# ──────────────────────────────────────────────────────────────
# Settings
# ──────────────────────────────────────────────────────────────

# Output directory
OUTPUT_DIR=./output
